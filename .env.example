# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/snaplink"

# --- Auth.js (bắt buộc, tạo bằng: npx auth secret) ---
AUTH_SECRET="openssl rand -base64 33"
AUTH_URL="http://localhost:3000"

# --- OAuth providers ---
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_PRO="price_..."          # Gói Pro, subscription hàng tháng
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Không bao giờ thêm tiền tố NEXT_PUBLIC_ cho secret key ở trên —
# chỉ biến NEXT_PUBLIC_APP_URL được phép lộ ra client vì nó không nhạy cảm.
